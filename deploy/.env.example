# ==============================================================================
# Portofolio Application Environment Variables
# Copy this file to .env and fill in the values for production deployment.
# ==============================================================================

# Next.js Server Configurations
PORT=3000
HOST=0.0.0.0

# ------------------------------------------------------------------------------
# yt-dlp Music Playback Configurations
# ------------------------------------------------------------------------------
# Path to the yt-dlp executable. Defaults to /var/www/abyndotxyz/bin/yt-dlp
YT_DLP_PATH="/var/www/abyndotxyz/bin/yt-dlp"

# Optional extra arguments to pass to yt-dlp (e.g. "--limit-rate 5M" or proxy configs)
YT_DLP_EXTRA_ARGS=""

# ------------------------------------------------------------------------------
# Upstash Redis / Vercel KV Configurations (Used for Session Caching)
# ------------------------------------------------------------------------------
KV_URL=""
REDIS_URL=""
KV_REST_API_URL=""
KV_REST_API_TOKEN=""
KV_REST_API_READ_ONLY_TOKEN=""

# ------------------------------------------------------------------------------
# Third-Party Integrations APIs
# ------------------------------------------------------------------------------
# GitHub Token (for fetching public projects and commit events)
GITHUB_TOKEN=""

# Location Auth Secret (used to authorize updating location details)
LOCATION_SECRET=""

# Umami Analytics Configurations
NEXT_PUBLIC_UMAMI_SCRIPT_URL=""
NEXT_PUBLIC_UMAMI_WEBSITE_ID=""
UMAMI_BASE_URL=""
UMAMI_WEBSITE_ID=""
UMAMI_AUTH_TOKEN=""

# Last.fm API Configurations (for tracking scrobbles and stats)
LASTFM_USERNAME=""
LASTFM_API_KEY=""
LASTFM_API_SHARED_SECRET=""

# Spotify Integration Configurations (for Now Playing sync)
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""
SPOTIFY_REFRESH_TOKEN=""
